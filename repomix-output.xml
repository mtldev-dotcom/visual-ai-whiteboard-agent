          background: "var(--bg-surface)",
          borderColor: "#93c5fd",
          borderTopWidth: "3px",
          boxShadow: "var(--shadow-card)",
        }}
      >
        <div className="px-3 pt-2">
          <p
            className="text-xs font-semibold"
            style={{ color: "var(--text-1)" }}
          >
            {item.content.title}
          </p>
          <p className="mt-1 text-xs" style={{ color: "var(--text-2)" }}>
