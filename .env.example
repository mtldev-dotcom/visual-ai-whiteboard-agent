# Application
APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://visual_whiteboard:visual_whiteboard_dev@localhost:5444/visual_whiteboard_ai

# Auth
AUTH_SECRET=replace-with-local-dev-secret
# Required for encrypting user-owned Telegram bot tokens at rest.
APP_ENCRYPTION_KEY=
# Optional: set to "disable" to block new account creation while keeping login enabled.
APP_SIGNUP=enable

# LLM Providers
LLM_PROVIDER=local
LLM_API_KEY=

# Telegram
# Users connect their own BotFather bot tokens from /settings.

# Scheduler / Jobs
SCHEDULER_SECRET=

# File Storage
STORAGE_PROVIDER=local
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
