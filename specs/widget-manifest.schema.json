{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WidgetManifest",
  "type": "object",
  "required": [
    "id",
    "name",
    "description",
    "version",
    "kind",
    "category",
    "renderStrategy",
    "supportedSizes",
    "permissions",
    "stateSchema"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": ["prebuilt", "custom_html"]
    },
    "category": {
      "type": "string"
    },
    "renderStrategy": {
      "type": "string",
      "enum": ["react_component", "sandboxed_iframe"]
    },
    "supportedSizes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "width", "height"],
        "properties": {
          "name": {
            "type": "string"
          },
          "width": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "height": {
            "type": "number",
            "exclusiveMinimum": 0
          }
        },
        "additionalProperties": false
      }
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "board.read",
          "board.write",
          "network.request",
          "storage.local",
          "tools.invoke"
        ]
      },
      "uniqueItems": true
    },
    "stateSchema": {
      "type": "object",
      "description": "JSON Schema describing widget instance state."
    },
    "sourceVersioned": {
      "type": "boolean",
      "description": "Required for generated/custom HTML widgets."
    }
  },
  "additionalProperties": false
}
